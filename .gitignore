# ── Secrets — NEVER commit these ─────────────────────────────────
#secret.yaml
*.plaintext.yaml
*-unencrypted.yaml
*-plain.yaml

# ── Ansible generated inventory (contains SSH key paths + IPs) ───
Infra/Ansible/inventory.ini
inventory.ini

# ── Sealed Secrets public cert (fetch fresh from cluster) ────────
sealed-secrets-pub.pem

# ── Terraform state (contains sensitive output values) ───────────
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
.terraform.lock.hcl

# ── Local environment files ───────────────────────────────────────
.env
.env.*
*.local

# ── Node / Yarn ───────────────────────────────────────────────────
node_modules/
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ── Build artifacts ───────────────────────────────────────────────
packages/app/dist/
packages/backend/dist/
dist/

# ── OS noise ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db